{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ld-patcher.local/schemas/execution_report.schema.json",
  "title": "ExecutionReport",
  "type": "object",
  "required": [
    "schema_type",
    "schema_version",
    "step",
    "status",
    "started_at",
    "finished_at",
    "messages",
    "artifacts",
    "log_paths",
    "summary"
  ],
  "properties": {
    "schema_type": { "const": "ExecutionReport" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "step": {
      "type": "string",
      "enum": ["detect", "validate", "apply", "build", "verify"]
    },
    "status": {
      "type": "string",
      "enum": ["ok", "warning", "failed"]
    },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "messages": { "type": "array", "items": { "type": "string" } },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "log_paths": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "object" }
  },
  "additionalProperties": true
}
