{
  "$schema": "../../schemas/verify_recipe.schema.json",
  "schema_type": "VerifyRecipe",
  "schema_version": 1,
  "enabled": true,
  "id": "sanity_cli",
  "display_name": "CLI sanity checks",
  "description": "Minimal command-line checks for a built ld.exe artifact.",
  "status": "verified_local",
  "checks": [
    {
      "type": "file_exists",
      "path": "{{drop_dir}}/ld.exe",
      "description": "ld.exe exists"
    },
    {
      "type": "command_exit_zero",
      "command": [
        "{{drop_dir}}/ld.exe",
        "--help"
      ],
      "description": "ld.exe --help exits successfully"
    },
    {
      "type": "stdout_regex",
      "command": [
        "{{drop_dir}}/ld.exe",
        "--help"
      ],
      "regex": "--dump-script-json",
      "description": "--help advertises the dump-script-json option"
    },
    {
      "type": "command_exit_zero",
      "command": [
        "{{drop_dir}}/ld.exe",
        "--version"
      ],
      "description": "ld.exe --version exits successfully"
    }
  ],
  "required_inputs": [
    "drop_dir"
  ],
  "success_policy": {
    "all_checks_must_pass": true
  },
  "result_artifacts": [],
  "notes": [
    "This recipe is locally verified against the 13.3.rel1 and 14.3.rel1 STM32 linker drops produced by ld_patcher in this workspace."
  ]
}
